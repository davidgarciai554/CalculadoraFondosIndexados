---
import Layout from "../layouts/Layout.astro";
import Parametros from "../components/Parametros.astro";
import Grafica from "../components/Grafica.astro";
---

<Layout>
  <main class="flex flex-col w-full gap-8">
    <div class="flex flex-col items-center text-center max-w-3xl mx-auto px-4 pt-4 pb-2">
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight">
        Simulador de <span class="text-primary">Inversiones</span>
      </h1>
      <p class="text-lg text-base-content/75 mt-4 leading-relaxed">
        Descubre el potencial de tu dinero a lo largo del tiempo. Esta herramienta te permite proyectar el crecimiento de tu capital, analizando el impacto del interés compuesto y tus aportaciones regulares para alcanzar tus metas financieras.
      </p>
    </div>
    <div class="flex w-full flex-col items-center gap-4">
      <div class="flex w-6/7 md:w-2/3 flex-col gap-4 items-center">
        <Parametros />
      </div>
    </div>
  </main>
</Layout>

---
import "../styles/global.css";
---

<!doctype html>
<html lang="en" data-theme="synthwave">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
		<meta name="generator" content={Astro.generator} />
		<title>Inversion en fondos indexados</title>
	</head>
	<body class="bg-base-100 text-base-content flex flex-col min-h-screen">
		<nav class="navbar bg-base-300 shadow-md">
			<div class="flex-1">
				<a href={import.meta.env.BASE_URL} class="btn btn-ghost text-xl">Calculadora de Fondos</a>
			</div>
			<div class="flex-none">
				<ul class="menu menu-horizontal px-1 font-semibold">
					<li><a href={import.meta.env.BASE_URL}>Inicio</a></li>
					<li><a href={`${import.meta.env.BASE_URL}objetivo`}>Objetivo de Ahorros</a></li>
				</ul>
			</div>
		</nav>
		<div class="flex-1 p-4 md:p-8">
			<slot />
		</div>
	</body>
</html>

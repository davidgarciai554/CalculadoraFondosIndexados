---
// TablaResultados.astro
---

<div class="card w-full bg-base-300 rounded-box overflow-hidden">
    <div class="overflow-x-auto w-full">
        <table class="table table-zebra">
            <thead class="bg-base-200">
                <tr>
                    <th>Año</th>
                    <th>Aportado</th>
                    <th>Intereses</th>
                    <th>Total</th>
                </tr>
            </thead>
            <tbody id="tablaResultados">
                <tr>
                    <td colspan="4" class="text-center">
                        Ingresa los datos para ver los resultados
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- Controles de paginación -->
    <div
        class="flex justify-between items-center p-4 bg-base-200 flex-wrap gap-2">
        <div class="text-sm">
            Mostrando página <span id="paginaActualInfo">0</span> de <span
                id="totalPaginasInfo">0</span
            >
        </div>
        <div class="join" id="paginacionControles">
            <!-- Los botones se generarán dinámicamente aquí -->
        </div>
    </div>
</div>

---
// src/components/Grafica.astro
---

<fieldset
  class="fieldset bg-base-200 border-base-300 rounded-box w-full border p-2 sm:p-4">
  <div id="chart"></div>
</fieldset>

<script>
  import ApexCharts from "apexcharts";

  const options = {
    colors: ["#f861b4", "#ff8904"],
    series: [
      {
        name: "Sin Intereses",
        data: [],
      },
      {
        name: "Con Intereses",
        data: [],
      },
    ],
    chart: {
      height: 350,
      type: "line",
      zoom: {
        enabled: false,
      },
      toolbar: {
        show: false,
      },
      foreColor: "#a1b1ff",
    },
    stroke: {
      curve: "smooth",
      width: 3,
    },
    markers: {
      size: 0,
      hover: {
        size: 6,
      },
    },
    dataLabels: {
      enabled: false,
    },
    title: {
      text: "Crecimiento de la Inversión",
      align: "left",
      style: {
        color: "#a1b1ff",
      },
    },
    grid: {
      borderColor: "#1c184b",
      row: {
        colors: ["#1c184b", "#16133d"],
        opacity: 1,
      },
    },
    xaxis: {
      categories: [],
      title: {
        text: "Años",
        style: {
          color: "#a1b1ff",
        },
      },
      labels: {
        style: {
          colors: "#a1b1ff",
        },
        rotate: -45,
        rotateAlways: false,
      },
    },
    yaxis: {
      title: {
        text: "Valor (€)",
        style: {
          color: "#a1b1ff",
        },
      },
      labels: {
        style: {
          colors: ["#a1b1ff"],
        },
        formatter: function (value: number) {
          return new Intl.NumberFormat("es-ES", {
            style: "currency",
            currency: "EUR",
            minimumFractionDigits: 0,
          }).format(value);
        },
      },
    },
    legend: {
      position: "top",
      horizontalAlign: "right",
      labels: {
        colors: "#a1b1ff",
      },
    },
    tooltip: {
      theme: "dark",
      style: {
        fontSize: "14px",
        fontFamily: "inherit",
      },
      x: {
        show: true,
      },
      y: {
        formatter: function (value: number) {
          return new Intl.NumberFormat("es-ES", {
            style: "currency",
            currency: "EUR",
            minimumFractionDigits: 2,
          }).format(value);
        },
      },
    },
    responsive: [
      {
        breakpoint: 640,
        options: {
          chart: {
            height: 280,
          },
          xaxis: {
            labels: {
              rotate: -45,
              rotateAlways: true,
            },
          },
          legend: {
            position: "bottom",
            horizontalAlign: "center",
          },
        },
      },
    ],
  };

  const chart = new ApexCharts(document.querySelector("#chart"), options);
  chart.render();

  // Exponer el chart globalmente para actualizarlo desde otros componentes
  (window as any).investmentChart = chart;
</script>

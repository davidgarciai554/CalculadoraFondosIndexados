---
// src/components/Grafica.astro
---

<fieldset
  class="fieldset bg-base-200 border-base-300 rounded-box w-full border p-4">
  <div id="chart"></div>
</fieldset>

<script>
  import ApexCharts from "apexcharts";

  const options = {
    colors: ["#f861b4", "#ff8904"],
    series: [
      {
        name: "Sin Intereses",
        data: [],
      },
      {
        name: "Con Intereses",
        data: [],
      },
    ],
    chart: {
      height: 350,
      type: "bar",
      zoom: {
        enabled: false,
      },
      toolbar: {
        show: false,
      },
      foreColor: "#a1b1ff", // ✅ Color global de texto
    },
    plotOptions: {
      bar: {
        horizontal: false,
        columnWidth: "55%",
        endingShape: "rounded",
      },
    },
    dataLabels: {
      enabled: false,
    },
    stroke: {
      show: true,
      width: 2,
      colors: ["transparent"],
    },
    title: {
      text: "Crecimiento de la Inversión",
      align: "left",
      style: {
        color: "#a1b1ff", // ✅ Color del título
      },
    },
    grid: {
      row: {
        colors: ["#1c184b", "#16133d"],
        opacity: 1,
      },
    },
    xaxis: {
      categories: [],
      title: {
        text: "Años",
        style: {
          color: "#a1b1ff", // ✅ Color del título del eje X
        },
      },
      labels: {
        style: {
          colors: "#a1b1ff", // ✅ Color de las etiquetas del eje X
        },
      },
    },
    yaxis: {
      title: {
        text: "Valor (€)",
        style: {
          color: "#a1b1ff", // ✅ Color del título del eje Y
        },
      },
      labels: {
        style: {
          colors: ["#a1b1ff"], // ✅ Color de las etiquetas del eje Y
        },
        formatter: function (value) {
          return new Intl.NumberFormat("es-ES", {
            style: "currency",
            currency: "EUR",
            minimumFractionDigits: 0,
          }).format(value);
        },
      },
    },
    legend: {
      position: "top",
      horizontalAlign: "right",
      labels: {
        colors: "#a1b1ff", // ✅ Color de la leyenda
      },
    },
    tooltip: {
      theme: "dark",
      style: {
        fontSize: "14px",
        fontFamily: "inherit",
      },
      x: {
        show: true,
      },
      y: {
        formatter: function (value) {
          return new Intl.NumberFormat("es-ES", {
            style: "currency",
            currency: "EUR",
            minimumFractionDigits: 2,
          }).format(value);
        },
      },
    },
  };

  const chart = new ApexCharts(document.querySelector("#chart"), options);
  chart.render();

  // Exponer el chart globalmente para actualizarlo desde otros componentes
  (window as any).investmentChart = chart;
</script>

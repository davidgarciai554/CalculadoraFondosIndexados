---
// src/components/Grafica.astro
---

<fieldset
  class="fieldset bg-base-200 border-base-300 rounded-box w-full max-w-full overflow-hidden border p-1 sm:p-4">
  <div id="chart"></div>
</fieldset>

<script>
  import ApexCharts from "apexcharts";

  // Función para obtener el valor hex de una variable de CSS (ej. oklch o hsl que daisyUI genera en rgb)
  // En las versiones más recientes de Tailwind/DaisyUI v4, estos colores los recuperamos computados
  function getThemeColor(variable) {
    const el = document.documentElement;
    const computed = getComputedStyle(el).getPropertyValue(variable).trim();
    
    // Si la variable de DaisyUI no está computada directamente en un formato que apexcharts entienda (hex/rgb/rgba)
    // Apexcharts no soporta oklch nativamente en todos sus campos, por lo que creamos un elemento temporal
    // para forzar al navegador a darnos el rgb computado del oklch.
    const tempEl = document.createElement("div");
    tempEl.style.color = `var(${variable})`;
    document.body.appendChild(tempEl);
    const rgbColor = getComputedStyle(tempEl).color;
    document.body.removeChild(tempEl);
    
    return rgbColor || computed;
  }

  const colorPrimary = getThemeColor('--color-primary');
  const colorSecondary = getThemeColor('--color-accent');
  const colorText = getThemeColor('--color-base-content');
  const colorGridLine = getThemeColor('--color-base-300');
  const colorGridArea1 = "transparent";
  const colorGridArea2 = getThemeColor('--color-base-200');

  const options = {
    colors: [colorPrimary, colorSecondary],
    series: [
      {
        name: "Sin Intereses",
        data: [],
      },
      {
        name: "Con Intereses",
        data: [],
      },
    ],
    chart: {
      height: 350,
      type: "line",
      zoom: {
        enabled: false,
      },
      toolbar: {
        show: false,
      },
      foreColor: colorText,
    },
    stroke: {
      curve: "smooth",
      width: 3,
    },
    markers: {
      size: 0,
      hover: {
        size: 6,
      },
    },
    dataLabels: {
      enabled: false,
    },
    title: {
      text: "Crecimiento de la Inversión",
      align: "left",
      style: {
        color: colorText,
      },
    },
    grid: {
      borderColor: colorGridLine,
      row: {
        colors: [colorGridArea1, colorGridArea2],
        opacity: 0.5,
      },
    },
    xaxis: {
      categories: [],
      title: {
        text: "Años",
        style: {
          color: colorText,
        },
      },
      labels: {
        style: {
          colors: colorText,
        },
        rotate: -45,
        rotateAlways: false,
      },
    },
    yaxis: {
      title: {
        text: "Valor (€)",
        style: {
          color: colorText,
        },
      },
      labels: {
        style: {
          colors: [colorText],
        },
        formatter: function (value: number) {
          return new Intl.NumberFormat("es-ES", {
            style: "currency",
            currency: "EUR",
            minimumFractionDigits: 0,
          }).format(value);
        },
      },
    },
    legend: {
      position: "top",
      horizontalAlign: "right",
      labels: {
        colors: colorText,
      },
    },
    tooltip: {
      theme: "dark",
      style: {
        fontSize: "14px",
        fontFamily: "inherit",
      },
      x: {
        show: true,
      },
      y: {
        formatter: function (value: number) {
          return new Intl.NumberFormat("es-ES", {
            style: "currency",
            currency: "EUR",
            minimumFractionDigits: 2,
          }).format(value);
        },
      },
    },
    responsive: [
      {
        breakpoint: 640,
        options: {
          chart: {
            height: 300,
          },
          xaxis: {
            labels: {
              rotate: -45,
              rotateAlways: true,
              style: {
                fontSize: '9px'
              }
            },
          },
          yaxis: {
            title: {
              text: undefined // Oculta el título "Valor (€)" en móvil para dar más espacio a la gráfica
            },
            labels: {
              style: {
                fontSize: '9px'
              },
              formatter: function (value: number) {
                // Formatear a 'k' o 'M' para ahorrar espacio en móvil
                if (value >= 1000000) return (value / 1000000).toFixed(1) + "M €";
                if (value >= 1000) return (value / 1000).toFixed(0) + "k €";
                return value.toString();
              }
            }
          },
          legend: {
            position: "bottom",
            horizontalAlign: "center",
            fontSize: '12px'
          },
        },
      },
    ],
  };

  const chart = new ApexCharts(document.querySelector("#chart"), options);
  chart.render();

  // Exponer el chart globalmente para actualizarlo desde otros componentes
  (window as any).investmentChart = chart;
</script>

---
// Parametros.astro
import TablaResultados from "./TablaResultados.astro";
import Grafica from "./Grafica.astro";
---

<div class="w-full max-w-4xl mx-auto px-2 py-3 sm:px-6 sm:py-6">
  <div class="flex flex-col gap-4 sm:gap-6">
    <!-- Formulario -->
    <form class="w-full" id="dynamicForm">
      <fieldset
        class="fieldset bg-base-200 border-base-300 rounded-box w-full border p-2 sm:p-4 md:p-6 space-y-2 sm:space-y-4 mx-0">
        <legend class="fieldset-legend text-base sm:text-lg font-semibold">
          Datos Inversion
        </legend>

        <div class="form-control w-full">
          <label class="label">
            <span class="label-text text-sm sm:text-base"
              >Aportacion inicial</span
            >
          </label>
          <input
            type="number"
            name="aportacionInicial"
            class="input input-bordered w-full input-sm sm:input-md"
            placeholder="Aportacion inicial"
            value="10000"
            min="0"
            step="1"
            required
          />
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-3 sm:gap-4">
          <div class="form-control w-full">
            <label class="label">
              <span class="label-text text-sm sm:text-base"
                >Aportacion por periodo</span
              >
            </label>
            <input
              type="number"
              name="aportacionPeriodo"
              class="input input-bordered w-full input-sm sm:input-md"
              placeholder="Aportacion por periodo"
              value="50"
              min="0"
              step="1"
              required
            />
          </div>
          <div class="form-control w-full">
            <label class="label">
              <span class="label-text text-sm sm:text-base"
                >Frecuencia de aportacion</span
              >
            </label>
            <select
              class="select select-bordered w-full select-sm sm:select-md"
              name="frecuencia"
              required>
              <option disabled>Elige la frecuencia</option>
              <option value="52">Semanal</option>
              <option value="26">Bisemanal</option>
              <option value="12" selected>Mensual</option>
              <option value="1">Anual</option>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-3 sm:gap-4">
          <div class="form-control">
            <label class="label">
              <span class="label-text text-sm sm:text-base">Tasa anual</span>
            </label>
            <label
              class="input input-bordered input-sm sm:input-md flex items-center gap-2">
              <input
                type="number"
                class="grow"
                placeholder="Tasa anual"
                name="tasaAnual"
                value="5"
                min="0"
                max="100"
                step="0.1"
                required
              />
              <span class="text-base-content/70 text-sm">%</span>
            </label>
          </div>
          <div class="form-control w-full">
            <label class="label">
              <span class="label-text text-sm sm:text-base">Años</span>
            </label>
            <input
              type="number"
              name="años"
              class="input input-bordered w-full input-sm sm:input-md"
              placeholder="Años"
              value="10"
              min="1"
              step="1"
              required
            />
          </div>
        </div>

        <div class="divider my-2"></div>

        <div class="form-control">
          <label class="label cursor-pointer justify-start gap-3 py-1">
            <input
              type="checkbox"
              class="checkbox checkbox-sm sm:checkbox-md"
              name="inflacion"
            />
            <span class="label-text text-sm sm:text-base"
              >¿Incluir inflacion en el calculo?</span
            >
          </label>
        </div>
      </fieldset>
    </form>

    <!-- Stats -->
    <div
      class="stats stats-vertical lg:stats-horizontal shadow bg-base-200 w-full">
      <div class="stat py-2 sm:py-4">
        <div class="stat-title text-xs sm:text-sm">Total Aportado</div>
        <div
          class="stat-value text-lg sm:text-2xl md:text-3xl text-primary"
          id="totalAportado">
          €0
        </div>
        <div class="stat-desc text-xs">Capital invertido</div>
      </div>

      <div class="stat py-2 sm:py-4">
        <div class="stat-title text-xs sm:text-sm">Intereses Ganados</div>
        <div
          class="stat-value text-lg sm:text-2xl md:text-3xl text-secondary"
          id="interesesGanados">
          €0
        </div>
        <div class="stat-desc text-xs">Rendimiento generado</div>
      </div>

      <div class="stat py-2 sm:py-4">
        <div class="stat-title text-xs sm:text-sm">Valor Final</div>
        <div
          class="stat-value text-lg sm:text-2xl md:text-3xl text-accent"
          id="valorFinal">
          €0
        </div>
        <div class="stat-desc text-xs">Total acumulado</div>
      </div>
    </div>

    <!-- Gráfica -->
    <Grafica />

    <!-- Tabla -->
    <TablaResultados />
  </div>

  <script>
    const form = document.getElementById("dynamicForm") as HTMLFormElement;

    interface ResultadoAnual {
      año: number;
      totalAportado: number;
      interesesAcumulados: number;
      valorTotal: number;
    }

    let paginaActual = 1;
    const resultadosPorPagina = 10;
    let todosLosResultados: ResultadoAnual[] = [];

    function calcularCrecimiento() {
      const formData = new FormData(form);

      const aportacionInicial =
        parseFloat(formData.get("aportacionInicial") as string) || 0;
      const aportacionPeriodo =
        parseFloat(formData.get("aportacionPeriodo") as string) || 0;
      const frecuenciaPorAño =
        parseInt(formData.get("frecuencia") as string) || 12;
      const tasaAnual = parseFloat(formData.get("tasaAnual") as string) || 0;
      const años = parseInt(formData.get("años") as string) || 0;

      const tasaPorPeriodo = tasaAnual / 100 / frecuenciaPorAño;
      const totalPeriodos = años * frecuenciaPorAño;

      const resultadosPorAño: ResultadoAnual[] = [];

      // Aportación inicial genera interés desde el primer periodo
      let saldo = aportacionInicial * (1 + tasaPorPeriodo);
      let totalAportado = aportacionInicial;

      for (let periodo = 1; periodo <= totalPeriodos; periodo++) {
        // Aportación al PRINCIPIO del periodo (genera interés en este periodo)
        saldo += aportacionPeriodo;
        totalAportado += aportacionPeriodo;
        saldo = saldo * (1 + tasaPorPeriodo);

        if (periodo % frecuenciaPorAño === 0) {
          const añoActual = periodo / frecuenciaPorAño;
          const interesesAcumulados = saldo - totalAportado;

          resultadosPorAño.push({
            año: añoActual,
            totalAportado: totalAportado,
            interesesAcumulados: interesesAcumulados,
            valorTotal: saldo,
          });
        }
      }

      return resultadosPorAño;
    }

    function formatearMoneda(valor: number): string {
      return new Intl.NumberFormat("es-ES", {
        style: "currency",
        currency: "EUR",
        minimumFractionDigits: 2,
      }).format(valor);
    }

    function reducirPuntosGrafica(resultados: ResultadoAnual[]) {
      const totalAños = resultados.length;
      const esMobile = window.innerWidth < 640;

      const maxPuntos = esMobile ? 10 : 20;

      if (totalAños <= maxPuntos) return resultados;

      const intervalo = Math.ceil(totalAños / maxPuntos);
      return resultados.filter(
        (_, index) => index % intervalo === 0 || index === totalAños - 1,
      );
    }

    function generarBotonesPaginacion(
      paginaActual: number,
      totalPaginas: number,
    ) {
      const contenedor = document.getElementById("paginacionControles");
      if (!contenedor) return;

      let html = "";

      html += `<button class="join-item btn btn-xs sm:btn-sm" id="btnPrimera" ${paginaActual === 1 ? "disabled" : ""}>«</button>`;
      html += `<button class="join-item btn btn-xs sm:btn-sm" id="btnAnterior" ${paginaActual === 1 ? "disabled" : ""}>‹</button>`;

      const maxBotones = 7;

      if (totalPaginas <= maxBotones) {
        for (let i = 1; i <= totalPaginas; i++) {
          const activo = i === paginaActual ? "btn-active" : "";
          html += `<button class="join-item btn btn-xs sm:btn-sm ${activo} btnPagina" data-pagina="${i}">${i}</button>`;
        }
      } else {
        if (paginaActual <= 4) {
          for (let i = 1; i <= 5; i++) {
            const activo = i === paginaActual ? "btn-active" : "";
            html += `<button class="join-item btn btn-xs sm:btn-sm ${activo} btnPagina" data-pagina="${i}">${i}</button>`;
          }
          html += `<button class="join-item btn btn-xs sm:btn-sm btn-disabled">...</button>`;
          html += `<button class="join-item btn btn-xs sm:btn-sm btnPagina" data-pagina="${totalPaginas}">${totalPaginas}</button>`;
        } else if (paginaActual >= totalPaginas - 3) {
          html += `<button class="join-item btn btn-xs sm:btn-sm btnPagina" data-pagina="1">1</button>`;
          html += `<button class="join-item btn btn-xs sm:btn-sm btn-disabled">...</button>`;
          for (let i = totalPaginas - 4; i <= totalPaginas; i++) {
            const activo = i === paginaActual ? "btn-active" : "";
            html += `<button class="join-item btn btn-xs sm:btn-sm ${activo} btnPagina" data-pagina="${i}">${i}</button>`;
          }
        } else {
          html += `<button class="join-item btn btn-xs sm:btn-sm btnPagina" data-pagina="1">1</button>`;
          html += `<button class="join-item btn btn-xs sm:btn-sm btn-disabled">...</button>`;
          for (let i = paginaActual - 1; i <= paginaActual + 1; i++) {
            const activo = i === paginaActual ? "btn-active" : "";
            html += `<button class="join-item btn btn-xs sm:btn-sm ${activo} btnPagina" data-pagina="${i}">${i}</button>`;
          }
          html += `<button class="join-item btn btn-xs sm:btn-sm btn-disabled">...</button>`;
          html += `<button class="join-item btn btn-xs sm:btn-sm btnPagina" data-pagina="${totalPaginas}">${totalPaginas}</button>`;
        }
      }

      html += `<button class="join-item btn btn-xs sm:btn-sm" id="btnSiguiente" ${paginaActual === totalPaginas ? "disabled" : ""}>›</button>`;
      html += `<button class="join-item btn btn-xs sm:btn-sm" id="btnUltima" ${paginaActual === totalPaginas ? "disabled" : ""}>»</button>`;

      contenedor.innerHTML = html;
      agregarEventListenersPaginacion();
    }

    function agregarEventListenersPaginacion() {
      document.getElementById("btnPrimera")?.addEventListener("click", () => {
        paginaActual = 1;
        actualizarTabla(paginaActual);
      });

      document.getElementById("btnAnterior")?.addEventListener("click", () => {
        if (paginaActual > 1) {
          paginaActual--;
          actualizarTabla(paginaActual);
        }
      });

      document.getElementById("btnSiguiente")?.addEventListener("click", () => {
        const totalPaginas = Math.ceil(
          todosLosResultados.length / resultadosPorPagina,
        );
        if (paginaActual < totalPaginas) {
          paginaActual++;
          actualizarTabla(paginaActual);
        }
      });

      document.getElementById("btnUltima")?.addEventListener("click", () => {
        const totalPaginas = Math.ceil(
          todosLosResultados.length / resultadosPorPagina,
        );
        paginaActual = totalPaginas;
        actualizarTabla(paginaActual);
      });

      document.querySelectorAll(".btnPagina").forEach((boton) => {
        boton.addEventListener("click", (e) => {
          const pagina = parseInt(
            (e.target as HTMLElement).getAttribute("data-pagina")!,
          );
          paginaActual = pagina;
          actualizarTabla(paginaActual);
        });
      });
    }

    function actualizarTabla(pagina: number) {
      const inicio = (pagina - 1) * resultadosPorPagina;
      const fin = inicio + resultadosPorPagina;
      const resultadosPagina = todosLosResultados.slice(inicio, fin);

      const tbody = document.getElementById("tablaResultados");
      if (!tbody) return;

      const añoActual = new Date().getFullYear();

      tbody.innerHTML = resultadosPagina
        .map(
          (resultado) => `
      <tr>
        <td class="px-1 sm:px-4">${añoActual + resultado.año}</td>
        <td class="px-1 sm:px-4">${formatearMoneda(resultado.totalAportado)}</td>
        <td class="px-1 sm:px-4">${formatearMoneda(resultado.interesesAcumulados)}</td>
        <td class="px-1 sm:px-4 font-bold">${formatearMoneda(resultado.valorTotal)}</td>
      </tr>
    `,
        )
        .join("");

      const totalPaginas = Math.ceil(
        todosLosResultados.length / resultadosPorPagina,
      );

      const paginaActualInfo = document.getElementById("paginaActualInfo");
      const totalPaginasInfo = document.getElementById("totalPaginasInfo");

      if (paginaActualInfo) paginaActualInfo.textContent = pagina.toString();
      if (totalPaginasInfo)
        totalPaginasInfo.textContent = totalPaginas.toString();

      generarBotonesPaginacion(pagina, totalPaginas);
    }

    function actualizarResultados() {
      try {
        const resultados = calcularCrecimiento();

        if (resultados.length === 0) return;

        todosLosResultados = resultados;
        paginaActual = 1;

        const ultimoAño = resultados[resultados.length - 1];

        const totalAportado = document.getElementById("totalAportado");
        const interesesGanados = document.getElementById("interesesGanados");
        const valorFinal = document.getElementById("valorFinal");

        if (totalAportado)
          totalAportado.textContent = formatearMoneda(ultimoAño.totalAportado);
        if (interesesGanados)
          interesesGanados.textContent = formatearMoneda(
            ultimoAño.interesesAcumulados,
          );
        if (valorFinal)
          valorFinal.textContent = formatearMoneda(ultimoAño.valorTotal);

        actualizarTabla(paginaActual);

        const chart = (window as any).investmentChart;
        if (chart) {
          const resultadosGrafica = reducirPuntosGrafica(resultados);

          const añoActual = new Date().getFullYear();

          const categorias = resultadosGrafica.map(
            (r) => `${añoActual + r.año}`,
          );
          const valoresConIntereses = resultadosGrafica.map((r) =>
            Math.round(r.valorTotal),
          );
          const valoresSinIntereses = resultadosGrafica.map((r) =>
            Math.round(r.totalAportado),
          );

          chart.updateOptions({
            xaxis: {
              categories: categorias,
            },
          });

          chart.updateSeries([
            {
              name: "Sin Intereses",
              data: valoresSinIntereses,
            },
            {
              name: "Con Intereses",
              data: valoresConIntereses,
            },
          ]);
        }
      } catch (error) {
        console.error("Error en el cálculo:", error);
      }
    }

    function debounce(func: Function, delay: number) {
      let timeoutId: ReturnType<typeof setTimeout>;
      return function (...args: any[]) {
        clearTimeout(timeoutId);
        timeoutId = setTimeout(() => func(...args), delay);
      };
    }

    const actualizarResultadosDebounced = debounce(actualizarResultados, 300);

    form.addEventListener("input", (e) => {
      const target = e.target as HTMLElement;

      if (
        target.tagName === "SELECT" ||
        (target.tagName === "INPUT" &&
          (target as HTMLInputElement).type === "checkbox")
      ) {
        actualizarResultados();
      } else {
        actualizarResultadosDebounced();
      }
    });

    document.addEventListener("DOMContentLoaded", () => {
      actualizarResultados();
    });
  </script>
</div>
